{
    # We use your email to register Let's Encrypt/ZeroSSL certificates
    email mdirfancse2023@gmail.com
}

# Azure Container Apps routes traffic to the container over HTTP and supplies
# the public TLS certificate at the ingress layer.
:80 {
    # Reverse proxy to Codexa AI on AKS
    handle /codexaai/api/* {
        uri strip_prefix /codexaai/api
        reverse_proxy http://20.204.189.207 {
            header_up Host api.20.204.189.207.sslip.io
        }
    }
    handle /codexaai/* {
        uri strip_prefix /codexaai
        reverse_proxy http://20.204.189.207 {
            header_up Host codexa.20.204.189.207.sslip.io
        }
    }
    handle /codexaai {
        uri strip_prefix /codexaai
        reverse_proxy http://20.204.189.207 {
            header_up Host codexa.20.204.189.207.sslip.io
        }
    }

    # Portfolio static files (everything else)
    handle {
        root * /usr/share/caddy
        encode gzip
        try_files {path} /index.html
        file_server
    }
}

# Your public domain
portfolio.34.180.9.45.sslip.io {
    root * /usr/share/caddy
    encode gzip
    try_files {path} /index.html
    file_server
}

# Old domain redirect
app.34.180.9.45.sslip.io {
    redir https://portfolio.34.180.9.45.sslip.io{uri}
}

# Also serve on HTTP for healthchecks or IP access, redirecting to HTTPS
http://34.180.9.45 {
    redir https://portfolio.34.180.9.45.sslip.io{uri}
}
