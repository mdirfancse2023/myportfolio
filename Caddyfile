    # We use your email to register Let's Encrypt/ZeroSSL certificates
    email mdirfancse2023@gmail.com
}

# Azure Container Apps routes traffic to the container over HTTP and supplies
# the public TLS certificate at the ingress layer.
:80 {
    # Redirect /codexaai to the dedicated subdomain
    handle /codexaai* {
        redir https://codexaai.virtualgyans.tech{uri} permanent
    }

    # Portfolio static files (everything else)
    handle {
        root * /usr/share/caddy
        encode gzip
        try_files {path} /index.html
        file_server
    }
}

# Your public domain
portfolio.virtualgyans.tech {
    root * /usr/share/caddy
    encode gzip
    try_files {path} /index.html
    file_server
}

# Old domain redirects
portfolio.34.180.9.45.sslip.io {
    redir https://portfolio.virtualgyans.tech{uri}
}

app.34.180.9.45.sslip.io {
    redir https://portfolio.virtualgyans.tech{uri}
}

# Also serve on HTTP for healthchecks or IP access, redirecting to HTTPS
http://34.180.9.45 {
    redir https://portfolio.virtualgyans.tech{uri}
}
